# Smart Attendance System - Environment Variables
# Copy this to .env and fill in your values

APP_NAME=Smart Attendance System
APP_VERSION=2.0.0
DEBUG=False

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database
DATABASE_URL=sqlite:///./attendance_db/attendance.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/smartattendance

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=smart_attendance

# Redis
REDIS_URL=redis://redis:6379/0

# File Paths
DATASET_PATH=../FaceAttendance/dataset
ENCODINGS_PATH=../FaceAttendance/encodings/encodings.pkl
